{
    "configurations": [
        {
            "name": "Launch Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/src/vscode-axaml"
            ],
            "outFiles": [
                "${workspaceFolder}/src/vscode-axaml/out/**/*.js"
            ],
            "preLaunchTask": "Build Extension",
            "sourceMaps": true,
        },
        {
            "name": "Only Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/src/vscode-axaml"
            ],
            "outFiles": [
                "${workspaceFolder}/src/vscode-axaml/out/**/*.js"
            ],
            "preLaunchTask": "Only Extension",
            "sourceMaps": true,
        },
        {
            "name": "Launch AXSG Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/src/XamlToCSharpGenerator/tools/vscode/axsg-language-server"
            ],
            "outFiles": [
                "${workspaceFolder}/src/XamlToCSharpGenerator/tools/vscode/axsg-language-server/**/*.js"
            ],
            "preLaunchTask": "Install AXSG Dependencies",
            "sourceMaps": true
        },
        {
            "name": "Only AXSG Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/src/XamlToCSharpGenerator/tools/vscode/axsg-language-server"
            ],
            "outFiles": [
                "${workspaceFolder}/src/XamlToCSharpGenerator/tools/vscode/axsg-language-server/**/*.js"
            ],
            "preLaunchTask": "Install AXSG Dependencies",
            "sourceMaps": true
        },
    ]
