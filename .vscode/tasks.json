{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Solution",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/src/AxamlLSP/AxamlLSP.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Only Extension",
            "command": "npm",
            "args": [
                "run",
                "compile"
            ],
            "type": "shell",
            "problemMatcher": "$tsc-watch",
            "options": {
                "cwd": "${workspaceFolder}/src/vscode-axaml"
            },
        },
                {
            "label": "Build Extension",
            "command": "npm",
                    "args": [
                "run",
                "compile"
            ],
            "type": "shell",
            "problemMatcher": "$tsc-watch",
            "options": {
                "cwd": "${workspaceFolder}/src/vscode-axaml"
            },
            "dependsOn": [
                "Build AXSG Language Server",
                "Build Solution Parser",
                "Build Axaml Language Server"
            ]
        },
        
        {
            "label": "Build AXSG Language Server",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/src/XamlToCSharpGenerator/src/XamlToCSharpGenerator.LanguageServer/XamlToCSharpGenerator.LanguageServer.csproj",
                "-c",
                "Release",
                "-o",
                "${workspaceFolder}/src/vscode-axaml/axsgServer"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build Solution Parser",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/SolutionParser/SolutionParser.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "/property:Configuration=Release",
                "--output",
                "${workspaceFolder}/src/vscode-axaml/solutionParserTool"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Install AXSG Dependencies",
            "command": "npm",
            "args": [
                "install"
            ],
            "type": "shell",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}/src/XamlToCSharpGenerator/tools/vscode/axsg-language-server"
            }
        },
        {
            "label": "Build Axaml Language Server",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/src/AxamlLSP/AxamlLanguageServer/AxamlLanguageServer.csproj",
                "-c",
                "Release",
                "-o",
                "${workspaceFolder}/src/vscode-axaml/axamlServer"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}